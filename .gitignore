.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Test files
check_permissions.php
fix_auth.php
fix_authentication_permanent.php
fix_unauthorized_final.php
test_auth.php
test_auth_final.php
